{
  "Pipelines": {
    "sync-system-events": {
      "Schedule": "every-5-minutes",
      "IsActive": false,
      "SourceProvider": {
        "Type": "FolderWatcherSourceProvider",
        "Parameters": {
          "folder": "data/Csv2Sqlite/input/system_events",
          "source": "csv"
        }
      },
      "TransformerProvider": {
        "Type": "TableTransformerProvider",
        "Parameters": {
          "transformers": "pipelines/plugin_transformers_events.json"
        }
      },
      "SinkProvider": {
        "Type": "SqliteSinkProvider",
        "Parameters": {
          "connectionString": "Data Source=data/Csv2Sqlite/output/systemstore.db;Mode=ReadWriteCreate;Cache=Shared;Pooling=True;Foreign Keys=True;",
          "batchSize": 50
        }
      }
    },
    "sync-system-metrics": {
      "SourceProvider": {
        "Type": "FolderWatcherSourceProvider",
        "Parameters": {
          "folder": "data/Csv2Sqlite/input/system_events",
          "source": "csv"
        }
      },
      "TransformerProvider": {
        "Type": "TableTransformerProvider",
        "Parameters": {
          "transformers": "pipelines/plugin_transformers_metrics.json"
        }
      },
      "SinkProvider": {
        "Type": "SqliteSinkProvider",
        "Parameters": {
          "connectionString": "Data Source=data/Csv2Sqlite/output/systemstore.db;Mode=ReadWriteCreate;Cache=Shared;Pooling=True;Foreign Keys=True;",
          "batchSize": 200
        }
      }
    }
  }
}
